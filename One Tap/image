local HttpService = game:GetService("HttpService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local RAW_URL = "https://raw.githubusercontent.com/1Qlua-RBXscript/1qlua/refs/heads/main/1Qlua_setting/Imeages"
local imageList = {}
local function fetchGitHub()
    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    local success, res
    if requestFunc then
        res = requestFunc({Url = RAW_URL, Method = "GET"})
        return res.Success and res.Body or nil
    else
        success, res = pcall(function() return HttpService:GetAsync(RAW_URL) end)
        return success and res or nil
    end
end

local function updateImageList()
    local data = fetchGitHub()
    if data then
        local tempTable = {}
        for line in data:gmatch("[^\r\n]+") do
            local cleanId = line:match("^%s*(.-)%s*$")
            if cleanId and cleanId ~= "" then
                table.insert(tempTable, cleanId)
            end
        end
        imageList = tempTable
    else
        imageList = {"rbxassetid://94766523133977"}
    end
end

updateImageList()

local function playEffect()
    if #imageList == 0 then return end
    
    local randomImage = imageList[math.random(1, #imageList)]
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "KillEffectGui"
    screenGui.Parent = CoreGui
    screenGui.IgnoreGuiInset = true 
    
    local imageLabel = Instance.new("ImageLabel")
    imageLabel.Size = UDim2.new(1, 0, 1, 0)
    imageLabel.Position = UDim2.new(0.5, 0, 0.5, 0)
    imageLabel.AnchorPoint = Vector2.new(0.5, 0.5)
    imageLabel.BackgroundTransparency = 1
    imageLabel.Image = randomImage 
    imageLabel.Parent = screenGui
    
    local tween = TweenService:Create(imageLabel, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        ImageTransparency = 1
    })
    
    task.wait(0.05)
    tween:Play()
    tween.Completed:Connect(function() screenGui:Destroy() end)
end

local function setupListener()
    local playerGui = player:WaitForChild("PlayerGui")
    local gameplay = playerGui:WaitForChild("Gameplay", 10)
    if not gameplay then return print("Gameplay не найден") end
    
    local kill = gameplay:WaitForChild("Kill", 10)
    local tabs = kill and kill:WaitForChild("Tabs", 10)
    
    if tabs then
        task.wait(2)
        local targetObject = tabs:FindFirstChild("TargetName") or tabs:GetChildren()[5]
        
        if targetObject then
            targetObject.Changed:Connect(function(prop)
                if prop == "Text" then
                    if targetObject.Text ~= "" and targetObject.Text ~= " " then
                        playEffect()
                    end
                end
            end)
        else
        end
    end
end

task.spawn(setupListener)
