do
    local dragging = false
    local dragStart = Vector2.new()
    local panelPosUDim = nil
    local panelSize = Vector2.new()

    characterPanel.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            panelPosUDim = characterPanel.Position
            panelSize = Vector2.new(characterPanel.AbsoluteSize.X, characterPanel.AbsoluteSize.Y)
        end
    end)

    characterPanel.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    characterPanel.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            local viewport = camera.ViewportSize
            local currentAbsX = panelPosUDim.X.Scale * viewport.X + panelPosUDim.X.Offset
            local currentAbsY = panelPosUDim.Y.Scale * viewport.Y + panelPosUDim.Y.Offset
            local newAbsX = currentAbsX + delta.X
            local newAbsY = currentAbsY + delta.Y
            local newOffsetX = newAbsX - panelPosUDim.X.Scale * viewport.X
            local newOffsetY = newAbsY - panelPosUDim.Y.Scale * viewport.Y

            characterPanel.Position = UDim2.new(panelPosUDim.X.Scale, newOffsetX, panelPosUDim.Y.Scale, newOffsetY)
        end
    end)
end

