local function updateSlider(data, setValue)
    local sliderFrame = data.object.Interact
    local sliderPos = sliderFrame.AbsolutePosition.X
    local sliderSize = sliderFrame.AbsoluteSize.X
    local relative
    if setValue then
        setValue = math.clamp(setValue, data.values[1], data.values[2])
        relative = (setValue - data.values[1]) / (data.values[2] - data.values[1])
    else
        local mouseX = mouse.X
        relative = (mouseX - sliderPos) / sliderSize
        relative = math.clamp(relative, 0, 1)
    end
    data.object.Progress.Size = UDim2.new(relative, 0, 1, 0)
    local value = data.values[1] + (data.values[2] - data.values[1]) * relative
    value = math.floor(value + 0.5)
    data.object.Information.Text = value .. " " .. data.name
    data.value = value
    if data.callback and not setValue then
        data.callback(value)
    elseif setValue then
        data.callback(value)
    end
end

