-- Serverhop и Rejoin (опционально)
characterPanel.Interactions.Serverhop.Interact.MouseButton1Click:Connect(function()
    local httpService = game:GetService("HttpService")
    local teleportService = game:GetService("TeleportService")
    local placeId = game.PlaceId
    local jobId = game.JobId
    local servers = {}
    local success, data = pcall(function()
        return httpService:JSONDecode(game:HttpGetAsync("https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100")).data
    end)
    if success then
        for _, v in ipairs(data) do
            if type(v) == "table" and v.maxPlayers > v.playing and v.id ~= jobId then
                table.insert(servers, v.id)
            end
        end
        if #servers > 0 then
            teleportService:TeleportToPlaceInstance(placeId, servers[math.random(1, #servers)], localPlayer)
        end
    end
end)

characterPanel.Interactions.Rejoin.Interact.MouseButton1Click:Connect(function()
    game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, game.JobId, localPlayer)
end)

-- Применяем значения слайдеров при появлении персонажа
local function applySlidersToCharacter(character)
    local humanoid = character:WaitForChild("Humanoid")
    for _, slider in ipairs(sliders) do
        if slider.callback then
            slider.callback(slider.value)
        end
    end
end

localPlayer.CharacterAdded:Connect(applySlidersToCharacter)
if localPlayer.Character then
    applySlidersToCharacter(localPlayer.Character)
end

