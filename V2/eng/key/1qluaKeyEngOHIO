    RainbowSpeed = 0.25
}
local function getOrCreateClouds()
    local terrain = workspace:FindFirstChildOfClass("Terrain")
    if not terrain then return nil end
    
    local clouds = terrain:FindFirstChildOfClass("Clouds")
    if not clouds then
        clouds = Instance.new("Clouds")
        clouds.Parent = terrain
    end
    return clouds
end
local terrain = workspace:WaitForChild("Terrain")
local originalClouds = terrain:FindFirstChildOfClass("Clouds")
local originalSettings = {
    Color = originalClouds and originalClouds.Color or Color3.fromRGB(255, 255, 255),
    Density = originalClouds and originalClouds.Density or 0.5,
    Cover = originalClouds and originalClouds.Cover or 0.5
}
local hue = 0
RunService.Heartbeat:Connect(function(deltaTime)
    local clouds = getOrCreateClouds()
    if not clouds then return end
    if not _G.SkyRainbowConfig.Enabled then
        clouds.Color = originalSettings.Color
        clouds.Density = originalSettings.Density
        clouds.Cover = originalSettings.Cover
        return
    end
    clouds.Density = 1
    clouds.Cover = 1
    local targetColor
    if _G.SkyRainbowConfig.Rainbow then
        hue = (hue + deltaTime * (_G.SkyRainbowConfig.RainbowSpeed or 0.25)) % 1
        targetColor = Color3.fromHSV(hue, 1, 1)
    else
        targetColor = _G.SkyRainbowConfig.StaticColor or Color3.fromRGB(255, 255, 255)
    end
    clouds.Color = targetColor
end)
