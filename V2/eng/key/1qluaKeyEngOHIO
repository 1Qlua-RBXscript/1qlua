local function monitorHealth(character)
    local humanoid = character:WaitForChild("Humanoid", 10)
    local hrp = character:WaitForChild("HumanoidRootPart", 10)
    
    if not humanoid or not hrp then return end
    
    local hasTeleported = false

    local connection
    connection = humanoid.HealthChanged:Connect(function(currentHealth)
        if currentHealth <= 0 then
            connection:Disconnect()
            return
        end
        if not _G.LowHealthTPConfig.Enabled then return end
        
        local maxHealth = humanoid.MaxHealth
        local currentPercent = (currentHealth / maxHealth) * 100
        
        local triggerPercent = _G.LowHealthTPConfig.HealthPercent or 20
        local targetPos = _G.LowHealthTPConfig.TargetPosition or Vector3.new(1203, 25, -950)
        local cooldownTime = _G.LowHealthTPConfig.Cooldown or 3
        
        if currentPercent <= triggerPercent and not hasTeleported then
            hasTeleported = true
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.CFrame = CFrame.new(targetPos)
            task.wait(cooldownTime)
            hasTeleported = false
        end
    end)
end

if player.Character then
    task.spawn(monitorHealth, player.Character)
end

player.CharacterAdded:Connect(function(character)
    monitorHealth(character)
