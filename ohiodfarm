            teleportLock = RunService.Heartbeat:Connect(function()
                if character and character:FindFirstChild("HumanoidRootPart") and bankCash and Settings.BankRobberyEnabled then
                    character.HumanoidRootPart.CFrame = bankCash:GetPivot() * CFrame.new(0, 2, 0)
                    character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.zero
                end
            end)
            
            while checkMoney() and Settings.BankRobberyEnabled do
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                task.wait(Settings.BankSpamDelay)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                task.wait(Settings.BankSpamDelay)
            end
            
            if teleportLock then teleportLock:Disconnect() end
            
            Stats.RobberiesCount = Stats.RobberiesCount + 1
            Stats.TotalEarned = Stats.TotalEarned + earnedThisTime
            RobberyCountLabel.Text = "🏦 Ограблено раз: " .. Stats.RobberiesCount
            
            if Settings.AutoReturnPosition and originalCFrame and character and character:FindFirstChild("HumanoidRootPart") then
                character.HumanoidRootPart.CFrame = originalCFrame
            end
            
            isRobbing = false
        end
    end
end)
