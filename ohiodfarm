local function findTargetItem()
    local gameFolder = workspace:FindFirstChild("Game")
    local entities = gameFolder and gameFolder:FindFirstChild("Entities")
    local itemPickup = entities and entities:FindFirstChild("ItemPickup")
    if not itemPickup then return nil, nil end
    
    local targetMap = {}
    if Settings.CollectWeaponParts then targetMap["Weapon Parts"] = true end
    if Settings.CollectMaterials then targetMap["Materials"] = true end
    if Settings.CollectScrap then targetMap["Scrap"] = true end
    if Settings.CollectElectronics then targetMap["Electronics "] = true end
    if Settings.CollectMedical then targetMap["Medical Supplies"] = true end
    
    for _, model in ipairs(itemPickup:GetChildren()) do
        if model:IsA("Model") then
            for _, part in ipairs(model:GetChildren()) do
                if part:IsA("BasePart") then
                    local prompt = part:FindFirstChildOfClass("ProximityPrompt")
                    if prompt and targetMap[prompt.ObjectText] then
                        return part, prompt
                    end
                end
            end
        end
    end
    return nil, nil
end

local COMPONENT_BOX_NAME = "Component Box"
local function getComponentBoxButton()
    local playerGui = player:FindFirstChild("PlayerGui")
    local backpack = playerGui and playerGui:FindFirstChild("Backpack")
    local holder = backpack and backpack:FindFirstChild("Holder")
    local bpFrame = holder and holder:FindFirstChild("Backpack")
    local mainFrame = bpFrame and bpFrame:FindFirstChild("Frame")
    if not mainFrame then return nil end
    
    for _, itemButton in ipairs(mainFrame:GetChildren()) do
        if itemButton.Name == "ItemButton" then
            local outsideRing = itemButton:FindFirstChild("OutsideRing")
            local viewport = outsideRing and outsideRing:FindFirstChild("ViewportFrame")
            if viewport then
                local itemModel = viewport:FindFirstChild(COMPONENT_BOX_NAME) or viewport:FindFirstChildOfClass("Model")
                if itemModel and (itemModel.Name == COMPONENT_BOX_NAME or string.find(itemModel.Name, "Component")) then
                    return itemButton
                end
            end
        end
    end
    return nil
end

