local isRobbing = false

local function checkMoney()
    local bankRobbery = workspace:FindFirstChild("BankRobbery")
    local bankCash = bankRobbery and bankRobbery:FindFirstChild("BankCash")
    local main = bankCash and bankCash:FindFirstChild("Main")
    local cashBillboard = main and main:FindFirstChild("CashBillboard")
    local moneyLabel = cashBillboard and cashBillboard:FindFirstChild("MoneyLabel")
    if moneyLabel and moneyLabel:IsA("TextLabel") and moneyLabel.Visible and moneyLabel.Text ~= "" and moneyLabel.Text ~= "0" then
        return moneyLabel, bankCash
    end
    return nil, nil
end

task.spawn(function()
    while true do
        task.wait(0.1)
        if not Settings.BankRobberyEnabled then continue end
        
        local moneyLabel, bankCash = checkMoney()
        if moneyLabel and bankCash and not isRobbing then
            isRobbing = true
            
            local moneyText = moneyLabel.Text
            local earnedThisTime = tonumber(moneyText:gsub("%D", "")) or 0
            
            local originalCFrame = nil
            if character and character:FindFirstChild("HumanoidRootPart") then
                originalCFrame = character.HumanoidRootPart.CFrame
            end
            
