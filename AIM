local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local isAiming = false
fovCircle = nil

local function isTargetVisible(targetPart, targetCharacter)
	if not checkWalls then return true end

	local cameraPos = Camera.CFrame.Position
	local targetPos = targetPart.Position
	local direction = (targetPos - cameraPos).Unit
	local distance = (targetPos - cameraPos).Magnitude

	local ignoreList = {Camera}
	if LocalPlayer.Character then
		for _, v in ipairs(LocalPlayer.Character:GetDescendants()) do
			if v:IsA("BasePart") then
				table.insert(ignoreList, v)
			end
		end
	end

	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
	raycastParams.FilterDescendantsInstances = ignoreList

	local result = workspace:Raycast(cameraPos, direction * distance, raycastParams)

	if result then
		if result.Instance:IsDescendantOf(targetCharacter) then
			return true
		else
			return false
		end
	else
		return true
	end
end

local function getBestTarget()
	local bestPart = nil
	local bestCharacter = nil
	local bestDist = math.huge
	local cameraPos = Camera.CFrame.Position
	local cameraDir = Camera.CFrame.LookVector

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			local character = player.Character
			if character then
				local humanoid = character:FindFirstChildOfClass("Humanoid")
				if humanoid and humanoid.Health > 0 then
					local targetPart = character:FindFirstChild("Head")
									or character:FindFirstChild("HumanoidRootPart")
									or character:FindFirstChild("Torso")
									or character:FindFirstChild("UpperTorso")
					if targetPart then
						local targetPos = targetPart.Position
						local dirToTarget = (targetPos - cameraPos).Unit
						local dot = cameraDir:Dot(dirToTarget)
						local angle = math.acos(math.clamp(dot, -1, 1)) * (180 / math.pi)

						if angle <= maxFov then
							if isTargetVisible(targetPart, character) then
								local dist = (targetPos - cameraPos).Magnitude
								if dist < bestDist then
									bestDist = dist
									bestPart = targetPart
									bestCharacter = character
								end
							end
						end
					end
				end
			end
		end
	end
	return bestPart, bestCharacter
end

local function createFovCircle()
	local success, drawingLib = pcall(function() return Drawing end)
	if success and drawingLib then
		fovCircle = Drawing.new("Circle")
		fovCircle.Visible = false
		fovCircle.Color = circleColor
		fovCircle.Transparency = circleTransparency
		fovCircle.NumSides = 60
		fovCircle.Filled = false
		fovCircle.Thickness = 2
	else
		fovCircle = nil
	end
end
local function updateFovCircle()
	if fovCircle and showFovCircle then
		local viewportSize = Camera.ViewportSize
		fovCircle.Position = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
		fovCircle.Radius = maxFov * circleRadiusFactor
		fovCircle.Visible = true
	elseif fovCircle then
		fovCircle.Visible = false
	end
end

