createFovCircle()

RunService.RenderStepped:Connect(function()
	updateFovCircle()

	if isAiming then
		local targetPart, targetChar = getBestTarget()
		if targetPart then
			Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPart.Position)
		end
	end
end)

