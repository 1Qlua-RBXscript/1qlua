local Window = Library:Init("Setting")

local LocalTab = Window:CreateMenu("Local", Color3.fromRGB(0, 150, 0))

local UITab = Window:CreateMenu("UI Size", Color3.fromRGB(150, 150, 150))

LocalTab:CreateToggle({
    Name = "Буст скорости",
    Description = "Включения буста",
    Key = "F",
    Default = false,
    Callback = function(state)
        if state then
            _G.EvadeActive = true
        else
            _G.EvadeActive = false 
        end
    end
})

LocalTab:CreateSlider({
    Name = "Максимальная скорость",
    Description = "Слайдер для максимальной скорости",
    Min = 1,
    Max = 10,
    Default = 5,
    Step = 0.1,
    Callback = function(value)
            _G.EvadeMaxSpeed = value
    end
})

LocalTab:CreateSlider({
    Name = "Скорости разгона",
    Description = "Слайдер для насколько быстро набирается скорость",
    Min = 0.1,
    Max = 5,
    Default = 0.2,
    Step = 0.1,
    Callback = function(value)
            _G.EvadeAccel = value
    end
})
 

LocalTab:CreateSlider({
    Name = "Высота прыжка",
    Description = "Слайдер для насколько высоко можешь прыгать",
    Min = 5,
    Max = 100,
    Default = 10,
    Step = 0.1,
    Callback = function(value)
    _G.JumpPower = value
    end
})

LocalTab:CreateSlider({
    Name = "Fov",
    Description = "Слайдер для поле зрения",
    Min = 5,
    Max = 120,
    Default = 90,
    Step = 0.1,
    Callback = function(value)
    _G.FOV = value
    end
})

LocalTab:CreateButton({
    Name = "Удалить невидимые стены",
    Description = "Да да мне лень делать описание",
    Key = "Z",
    Callback = function()
local LP = game:GetService("Players").LocalPlayer
local Players = game:GetService("Players")
pcall(function()
    local char = LP.Character
    local allPlayers = Players:GetPlayers()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and v.Transparency == 1 then
            local isPlayer = false
            
            if char and v:IsDescendantOf(char) then 
                isPlayer = true 
            end
            
            if not isPlayer then
                for _, p in pairs(allPlayers) do
                    if p.Character and v:IsDescendantOf(p.Character) then
                        isPlayer = true
                        break
                    end
                end
            end
            
            if not isPlayer then
                v.CanCollide = false
            end
        end
    end
end)
    end 
})

LocalTab:CreateSubtitle("Есть идеи что добавить?")

LocalTab:CreateTextBox({
    Name = "Имя",
    Description = "Что вписать",
    Placeholder = "Text",
    Callback = function(text, enterPressed) 
        print(text)
    end,
})

LocalTab:CreateButton({
    Name = "Есть идеи что добавить? (https://discord.gg/5n8AjWAbJn)",
    Description = "напишите нам в дискорд (КОПИРУЕТ СЫЛЛКУ НА ДИСКОРД)",
    Callback = function()
        setclipboard("https://discord.gg/5n8AjWAbJn")
    end 
})


UITab:CreateSlider({
    Name = "Размер меню",
    Description = "Общий масштаб всего окна ",
    Min = 0.5, Max = 2.0, Default = 0.8, Step = 0.1,
    Callback = function(value)
    wait(0.3)
        Window.UserScaleMult = value
        if Window._ApplyUserSize then Window._ApplyUserSize() end
    end
})
UITab:CreateButton({
    Name = "Сброс размера",
    Description = "Вернуть стандартный размер и положение окна",
    Callback = function()
        Window.UserScaleMult = 1
        Window.UserOffsetX = 0
        Window.UserOffsetY = 0
        if Window._ApplyUserSize then Window._ApplyUserSize() end
    end 
})
Window:Close()

local function start()
    if not Window then
        task.wait(0.2)
    end

    if Window and Window.Close then 
        Window:Close() 
    end
    UI.Enabled = true
    notificationContainer.Visible = true
    toastsContainer.Visible = true
    addCustomButton("Settings", {
        image1 = 9753762469,
        image2 = 9753762469,
        color1 = Color3.fromRGB(211, 141, 55),
        color2 = Color3.fromRGB(0, 170, 127),
        script1 = function()
            if Window and Window.Close then Window:Close() end
        end,
        script2 = function() 
            if Window and Window.Open then Window:Open() end
        end
    })
    openSmartBar() 
    task.spawn(function()
        while UI.Enabled do
            if smartBar and smartBar:FindFirstChild("Time") then
                smartBar.Time.Text = os.date("%H") .. ":" .. os.date("%M")
            end
            task.wait(1)
        end
    end)
end

start()

_G.EvadeActive = false
_G.EvadeStartSpeed = 1.0
_G.EvadeMaxSpeed = 5.0
_G.EvadeAccel = 0.2
_G.EvadeDecel = 4.0
local currentMult = _G.EvadeStartSpeed
local p = game:GetService("Players").LocalPlayer
game:GetService("RunService").RenderStepped:Connect(function(dt)
    if not _G.EvadeActive then currentMult = _G.EvadeStartSpeed return end
    local c = p.Character
    local r = c and c:FindFirstChild("HumanoidRootPart")
    local h = c and c:FindFirstChildOfClass("Humanoid")
    if r and h and h.Health > 0 then
        if h.MoveDirection.Magnitude > 0 then
            currentMult = math.min(_G.EvadeMaxSpeed, currentMult + (_G.EvadeAccel * dt))
            if currentMult > _G.EvadeStartSpeed then
                r.CFrame = r.CFrame + (h.MoveDirection * ((currentMult - _G.EvadeStartSpeed) * 15) * dt)
            end
        else
            currentMult = math.max(_G.EvadeStartSpeed, currentMult - (_G.EvadeDecel * dt))
        end
    end
end)


_G.JumpPower = 20
_G.JumpEnabled = true

local LP = game:GetService("Players").LocalPlayer
local RS = game:GetService("RunService")

RS.Heartbeat:Connect(function()
    if not _G.JumpEnabled then return end
    pcall(function()
        local char = LP.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.UseJumpPower = true
                if hum.JumpPower ~= _G.JumpPower then
                    hum.JumpPower = _G.JumpPower
                end
            end
        end
    end)
end)

_G.FOV = 90
_G.FOVEnabled = true
local RS = game:GetService("RunService")
pcall(function() RS:UnbindFromRenderStep("ForceFOV") end)
RS:BindToRenderStep("ForceFOV", Enum.RenderPriority.Camera.Value + 1, function()
    if not _G.FOVEnabled then return end
    local C = workspace.CurrentCamera
    if C then
        C.FieldOfView = _G.FOV
    end
end)
