        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1, TextSize = 18,
        Size = UDim2.new(0, 47, 0, 42),
        ZIndex = 6, ClearTextOnFocus = false,
    })
    New("UIStroke", {Parent = KeyBox, Color = Color3.fromRGB(85, 85, 85)})
    New("UICorner", {Parent = KeyBox})

    local function runCallback()
        local ok, err = pcall(callback)
        if not ok then  end
    end

    ClickBtn.MouseButton1Click:Connect(function()
        Tween(IconBox, 0.1, {BackgroundColor3 = Color3.fromRGB(60, 160, 0)})
        wait(0.1)
        Tween(IconBox, 0.1, {BackgroundColor3 = Color3.fromRGB(37, 97, 0)})
        runCallback()
    end)

    local currentKey = key
    KeyText.Focused:Connect(function() KeyText.Text = "" end)
    KeyText:GetPropertyChangedSignal("Text"):Connect(function()
        if KeyText.Text ~= "" and #KeyText.Text > 0 then
            currentKey = KeyText.Text:upper():sub(1,1)
            KeyText.Text = currentKey
        end
    end)
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.UserInputType == Enum.UserInputType.Keyboard and currentKey then
            if input.KeyCode.Name:upper() == currentKey:upper() then
                runCallback()
            end
        end
    end)

    return {
        SetText = function(_, t) name = t end,
        Fire = runCallback,
    }
end

function Library:CreateSlider(opts)
    opts = opts or {}
    local name = opts.Name or "Slider"
    local description = opts.Description or ""
    local min = opts.Min or 0
    local max = opts.Max or 100
    local default = opts.Default or min
    local step = opts.Step or 1
    local callback = opts.Callback or function() end

    local decimals = 0
    do
        local s = tostring(step)
        local dot = s:find("%.")
        if dot then decimals = #s - dot end
    end
    local function formatVal(v)
        if decimals > 0 then
            return string.format("%." .. decimals .. "f", v)
        else
            return tostring(math.floor(v + 0.5))
        end
    end
    local function snapToStep(v)
        if step <= 0 then return v end
        local n = math.floor((v - min) / step + 0.5)
        return min + n * step
    end

    local Container = New("Frame", {
        Parent = self.Scroll,
        Size = UDim2.new(0, 917, 0, 60),
        BackgroundTransparency = 1, Name = "Slider",
    })
    local BG = New("Frame", {
        Parent = Container,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0, 400, 0.494, 1),
        Size = UDim2.new(0, 800, 0, 56),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(32, 32, 32),
    })
    New("UICorner", {Parent = BG})
    local Track = New("Frame", {
        Parent = Container, Name = "Slider",
        Position = UDim2.new(0.0164, 0, 0.333, 0),
        Size = UDim2.new(0, 259, 0, 22),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(24, 25, 30),
    })
    New("UIStroke", {Parent = Track, Color = Color3.fromRGB(85, 85, 85)})
    New("UICorner", {Parent = Track})
    local Fill = New("Frame", {
        Parent = Track, Name = "Fill",
        Position = UDim2.new(-0.004, 0, 0, 0),
        Size = UDim2.new(0, 0, 0, 22),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(25, 134, 0),
    })
    New("UIStroke", {Parent = Fill, Color = Color3.fromRGB(66, 188, 0)})
    New("UICorner", {Parent = Fill})
    local ValueLabel = New("TextLabel", {
        Parent = Fill, RichText = true,
        TextColor3 = Color3.new(1, 1, 1),
        Text = formatVal(default),
        TextXAlignment = Enum.TextXAlignment.Right,
        TextSize = 22, Name = "Value",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -8, 0.5, 0),
        AnchorPoint = Vector2.new(1, 0.5),
        Size = UDim2.new(0, 80, 0, 24), ZIndex = 2,
    })
    local ClickArea = New("ImageButton", {
        Parent = Track,
        Size = UDim2.new(1, 0, 1, 0), 
        BackgroundTransparency = 1, ZIndex = 3,
    })
    New("TextLabel", {
        Parent = Container, RichText = true,
        TextColor3 = Color3.fromRGB(141, 141, 141),
        Text = description,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 13, Name = "description",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.3119, 0, 0.633, -4),
        Size = UDim2.new(0, 615, 0, 20), ZIndex = 2,
    })
    New("TextLabel", {
        Parent = Container, RichText = true,
        TextColor3 = Color3.new(1, 1, 1), Text = name,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 26, Name = "name",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.3119, 0, 0.233, -2),
        Size = UDim2.new(0, 615, 0, 24), ZIndex = 2,
    })

    local currentValue = default
    local maxWidth = 259

    local function setValue(val)
        val = math.clamp(val, min, max)
        val = snapToStep(val)
        val = math.clamp(val, min, max)
        currentValue = val
        local percent = (max - min) > 0 and ((currentValue - min) / (max - min)) or 0
        Fill.Size = UDim2.new(0, maxWidth * percent, 0, 22)
        ValueLabel.Text = formatVal(currentValue)
        local ok, err = pcall(callback, currentValue)
        if not ok then print()("[SWAG SUS]:", err) end
    end

    setValue(default)

    local dragging = false
    ClickArea.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local mouseX = input.Position.X
            local trackX = Track.AbsolutePosition.X
            local percent = math.clamp((mouseX - trackX) / Track.AbsoluteSize.X, 0, 1)
            local newVal = min + (max - min) * percent
            setValue(newVal)
        end
    end)

    return {
        Set = function(_, v) setValue(v) end,
        Get = function() return currentValue end,
    }
end

