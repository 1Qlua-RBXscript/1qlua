        math.min(color.G + 0.4, 1),
        math.min(color.B + 0.4, 1)
    )
    New("UIGradient", {
        Parent = Stroke,
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, lightColor),
            ColorSequenceKeypoint.new(0.761, Color3.fromRGB(88, 97, 112)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(88, 97, 112)),
        },
        Offset = Vector2.new(0, -0.5), Rotation = 49,
    })

    local MenuFrame = New("Frame", {
        Parent = self.FrameF, Name = name, LayoutOrder = 2,
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 486, 0.5, 0),
        Size = UDim2.new(0, 973, 0, 774),
    })
    local MenuInner = New("Frame", {
        Parent = MenuFrame,
        Size = UDim2.new(0, 973, 0, 720),
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0.08, 0),
    })
    local Scroll = New("ScrollingFrame", {
        Parent = MenuInner,
        ScrollBarImageColor3 = Color3.new(0, 0, 0),
        ScrollBarThickness = 4,
        Size = UDim2.new(0, 940, 0, 689),
        BackgroundTransparency = 1, Active = true,
        Position = UDim2.new(0.0175, 0, 0.019, 0),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
    })
    New("UIListLayout", {
        Parent = Scroll,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 8),
    })
    New("UIPadding", { Parent = Scroll, PaddingTop = UDim.new(0, 8) })

    menu.Frame = MenuFrame
    menu.Scroll = Scroll
    menu.Elements = {}

    Btn.MouseButton1Click:Connect(function() self:ShowMenu(menu) end)
    table.insert(self.Menus, menu)
    setmetatable(menu, {__index = self})
    menu.CreateButton = Library.CreateButton
    menu.CreateSlider = Library.CreateSlider
    menu.CreateToggle = Library.CreateToggle
    menu.CreateSubtitle = Library.CreateSubtitle
    menu.CreateTextBox = Library.CreateTextBox
    return menu
end

