        Parent = TopBar, Name = "CloseButton",
        Size = UDim2.new(0, 30, 0, 30),
        BackgroundTransparency = 1,
        Position = UDim2.new(0.965, 0, 0.015, 0),
        ZIndex = 6,
    })
    CloseBtn.MouseButton1Click:Connect(function() end)

    New("UICorner", {Parent = CloseBtn})
    self.CloseBtn = CloseBtn

    self.BackArrows = {BackArrow1, BackArrow2, BackArrow3}
    self.BackButton = BackButton

    BackButton.MouseButton1Click:Connect(function() self:ShowSettings() end)


    local DragHandle = New("Frame", {
        Parent = TopBar, Name = "DragHandle",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 54),
        Position = UDim2.new(0, 0, 0, 0),
        ZIndex = 1,
    })
    self.DragHandle = DragHandle

    self:MakeDraggable(Frame2, DragHandle)
    self:SetupAdaptiveScale(Frame2)
    return self
end

function Library:Open()
    self.IsOpen = true
    self.Frame2.Visible = true
    if self._UpdateScale then self._UpdateScale() end
    if self._ApplyUserSize then self._ApplyUserSize() end
end

function Library:Close()
    self.IsOpen = false
    self.Frame2.Visible = false
end

function Library:Toggle()
    if self.IsOpen then self:Close() else self:Open() end
end

function Library:MakeDraggable(frame, dragArea)
    local dragging, dragInput, dragStart, startPos
    dragArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    dragArea.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

function Library:SetupAdaptiveScale(frame)
    local BASE_SIZE = Vector2.new(873, 783)
    local MIN_SCALE = 0.3
    local MAX_SCALE = 2
    local SCREEN_PADDING = 40

    self.UserScaleMult = 1
    self.UserOffsetX = 0
    self.UserOffsetY = 0

    local UIScaleInst = New("UIScale", { Parent = frame, Scale = 1 })
    self.UIScaleInst = UIScaleInst

    local function UpdateScale()
        local cam = workspace.CurrentCamera
        if not cam then return end
        local viewport = cam.ViewportSize
        if viewport.X <= 0 or viewport.Y <= 0 then return end
        local availableX = math.max(viewport.X - SCREEN_PADDING, 1)
        local availableY = math.max(viewport.Y - SCREEN_PADDING, 1)
        local scaleX = availableX / BASE_SIZE.X
        local scaleY = availableY / BASE_SIZE.Y
        local scale = math.min(scaleX, scaleY, 1)
        if UserInputService.TouchEnabled and not UserInputService.MouseEnabled then
            scale = scale * 0.85
        end
        scale = scale * (self.UserScaleMult or 1)
        scale = math.clamp(scale, MIN_SCALE, MAX_SCALE)
        Tween(UIScaleInst, 0.2, {Scale = scale})
    end

    local function ApplyUserSize()
        frame.Position = UDim2.new(0.5, self.UserOffsetX or 0, 0.5, self.UserOffsetY or 0)
        UpdateScale()
    end

    self._UpdateScale = UpdateScale
    self._ApplyUserSize = ApplyUserSize

    if workspace.CurrentCamera then
        workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(UpdateScale)
    end
    workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
        local cam = workspace.CurrentCamera
        if cam then
            cam:GetPropertyChangedSignal("ViewportSize"):Connect(UpdateScale)
            UpdateScale()
        end
    end)
    UpdateScale()
end

function Library:ShowSettings()
    self.SettingFrame.LayoutOrder = 1
    for _, menu in ipairs(self.Menus) do
        menu.Frame.LayoutOrder = 2
    end
    self.TitleLabel.Text = self.DefaultTitle
    self.CurrentMenu = nil
    for _, arrow in ipairs(self.BackArrows) do arrow.Visible = false end
    self.BackButton.Visible = false
end

function Library:ShowMenu(menu)
    self.SettingFrame.LayoutOrder = 2
    for _, m in ipairs(self.Menus) do
        m.Frame.LayoutOrder = (m == menu) and 1 or 2
    end
    self.TitleLabel.Text = menu.Name
    self.CurrentMenu = menu
    for _, arrow in ipairs(self.BackArrows) do arrow.Visible = true end
    self.BackButton.Visible = true
end

