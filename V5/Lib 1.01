        Parent = Container, RichText = true,
        TextColor3 = Color3.new(1, 1, 1), Text = name,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 26, Name = "name",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.1036, 0, 0.183, -2),
        Size = UDim2.new(0, 615, 0, 24), ZIndex = 2,
    })
    New("TextLabel", {
        Parent = Container, RichText = true,
        TextColor3 = Color3.fromRGB(141, 141, 141),
        Text = description,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 13, Name = "description",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.1036, 0, 0.583, -4),
        Size = UDim2.new(0, 615, 0, 20), ZIndex = 2,
    })

    local currentText = placeholder

    Input.Focused:Connect(function()
        if Input.Text == placeholder then Input.Text = "" end
    end)
    Input.FocusLost:Connect(function(enterPressed)
        currentText = Input.Text
        if currentText == "" then
            Input.Text = placeholder
        end
        local ok, err = pcall(callback, currentText, enterPressed)
        if not ok then end
    end)

    return {
        SetText = function(_, t) currentText = t; Input.Text = t end,
        GetText = function() return currentText end,
    }
end

return Library 
end)()

