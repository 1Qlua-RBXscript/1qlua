        Parent = MenusHolder,
        SortOrder = Enum.SortOrder.LayoutOrder,
        CellSize = UDim2.new(0, 292, 0, 134),
        CellPadding = UDim2.new(0, 15, 0, 15),
    })
    self.SettingFrame = SettingFrame
    self.MenusHolder = MenusHolder

    local TopBar = New("Frame", {
