        AutomaticCanvasSize = Enum.AutomaticSize.Y,
    })
    New("UIListLayout", {
        Parent = Scroll,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 8),
    })
    New("UIPadding", { Parent = Scroll, PaddingTop = UDim.new(0, 8) })

    menu.Frame = MenuFrame
    menu.Scroll = Scroll
    menu.Elements = {}

    Btn.MouseButton1Click:Connect(function() self:ShowMenu(menu) end)
