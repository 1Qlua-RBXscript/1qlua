    setmetatable(menu, {__index = self})
    menu.CreateButton = Library.CreateButton
    menu.CreateSlider = Library.CreateSlider
    menu.CreateToggle = Library.CreateToggle
    menu.CreateSubtitle = Library.CreateSubtitle
    menu.CreateTextBox = Library.CreateTextBox
    return menu
end

function Library:CreateButton(opts)
    opts = opts or {}
    local name = opts.Name or "Button"
    local description = opts.Description or ""
    local callback = opts.Callback or function() end
    local key = opts.Key

    local fillColor = opts.Color and Darken(opts.Color, 0.12) or Color3.fromRGB(37, 97, 0)
    local strokeColor = opts.Color and Lighten(opts.Color, 0.3) or Color3.fromRGB(0, 157, 31)

    local Container = New("Frame", {
        Parent = self.Scroll,
        Size = UDim2.new(0, 917, 0, 60),
        BackgroundTransparency = 1, Name = "Butten",
    })
    local IconBox = New("Frame", {
        Parent = Container,
        Size = UDim2.new(0, 68, 0, 36), Name = "Butten",
        Position = UDim2.new(0.0164, 0, 0.197, 0),
        BorderSizePixel = 0,
        BackgroundColor3 = fillColor,
        ZIndex = 2,
    })
    local IconStroke = New("UIStroke", {Parent = IconBox, Color = strokeColor})
    New("UICorner", {Parent = IconBox})
    local BG = New("Frame", {
        Parent = Container,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0, 400, 0.494, 1),
        Size = UDim2.new(0, 800, 0, 56),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(32, 32, 32),
    })
    New("UICorner", {Parent = BG})
    local ClickBtn = New("ImageButton", {
        Parent = Container,
        Size = UDim2.new(0, 901, 0, 56),
        BackgroundTransparency = 1,
        Position = UDim2.new(0.05, 0, 0.04, 0),
        ZIndex = 4,
    })
    New("TextLabel", {
        Parent = Container, RichText = true,
        TextColor3 = Color3.new(1, 1, 1), Text = name,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 26, Name = "name",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.1036, 0, 0.233, -2),
        Size = UDim2.new(0, 806, 0, 24), ZIndex = 2,
    })
    New("TextLabel", {
        Parent = Container, RichText = true,
        TextColor3 = Color3.fromRGB(141, 141, 141),
        Text = description,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 13, Name = "description",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.1036, 0, 0.633, -4),
        Size = UDim2.new(0, 806, 0, 20), ZIndex = 2,
    })
    local KeyBox = New("Frame", {
        Parent = Container, Size = UDim2.new(0, 50, 0, 42),
        Name = "Key",
        Position = UDim2.new(0.7995, 0, 0.160, 0),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(28, 30, 35),
        ZIndex = 6, Visible = key ~= nil,
    })
    local KeyText = New("TextBox", {
        Parent = KeyBox, RichText = true,
        TextColor3 = Color3.new(1, 1, 1),
        Text = key or "",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1, TextSize = 18,
        Size = UDim2.new(0, 47, 0, 42),
        ZIndex = 6, ClearTextOnFocus = false,
    })
    New("UIStroke", {Parent = KeyBox, Color = Color3.fromRGB(85, 85, 85)})
    New("UICorner", {Parent = KeyBox})

    local function runCallback()
        local ok, err = pcall(callback)
        if not ok then  end
    end

    ClickBtn.MouseButton1Click:Connect(function()
        Tween(IconBox, 0.1, {BackgroundColor3 = Lighten(fillColor, 0.15)})
        wait(0.1)
        Tween(IconBox, 0.1, {BackgroundColor3 = fillColor})
        runCallback()
    end)

    local currentKey = key
    KeyText.Focused:Connect(function() KeyText.Text = "" end)
    KeyText:GetPropertyChangedSignal("Text"):Connect(function()
        if KeyText.Text ~= "" and #KeyText.Text > 0 then
            currentKey = KeyText.Text:upper():sub(1,1)
            KeyText.Text = currentKey
        end
    end)
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.UserInputType == Enum.UserInputType.Keyboard and currentKey then
            if input.KeyCode.Name:upper() == currentKey:upper() then
                runCallback()
            end
        end
    end)

    return {
        SetText = function(_, t) name = t end,
        SetColor = function(_, c)
            fillColor = Darken(c, 0.12)
            strokeColor = Lighten(c, 0.3)
            IconBox.BackgroundColor3 = fillColor
            IconStroke.Color = strokeColor
        end,
        Fire = runCallback,
    }
end

function Library:CreateSlider(opts)
    opts = opts or {}
    local name = opts.Name or "Slider"
    local description = opts.Description or ""
    local min = opts.Min or 0
    local max = opts.Max or 100
    local default = opts.Default or min
    local step = opts.Step or 1
    local callback = opts.Callback or function() end

    local decimals = 0
    do
        local s = tostring(step)
        local dot = s:find("%.")
        if dot then decimals = #s - dot end
    end
    local function formatVal(v)
        if decimals > 0 then
            return string.format("%." .. decimals .. "f", v)
        else
            return tostring(math.floor(v + 0.5))
        end
    end
    local function snapToStep(v)
        if step <= 0 then return v end
        local n = math.floor((v - min) / step + 0.5)
        return min + n * step
    end

    local fillColor = opts.Color and Darken(opts.Color, 0.12) or Color3.fromRGB(25, 134, 0)
    local strokeColor = opts.Color and Lighten(opts.Color, 0.3) or Color3.fromRGB(66, 188, 0)

    local Container = New("Frame", {
        Parent = self.Scroll,
        Size = UDim2.new(0, 917, 0, 60),
        BackgroundTransparency = 1, Name = "Slider",
    })
    local BG = New("Frame", {
        Parent = Container,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0, 400, 0.494, 1),
        Size = UDim2.new(0, 800, 0, 56),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(32, 32, 32),
    })
    New("UICorner", {Parent = BG})
    local Track = New("Frame", {
        Parent = Container, Name = "Slider",
        Position = UDim2.new(0.0164, 0, 0.333, 0),
        Size = UDim2.new(0, 259, 0, 22),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(24, 25, 30),
    })
    New("UIStroke", {Parent = Track, Color = Color3.fromRGB(85, 85, 85)})
    New("UICorner", {Parent = Track})
    local Fill = New("Frame", {
        Parent = Track, Name = "Fill",
        Position = UDim2.new(-0.004, 0, 0, 0),
        Size = UDim2.new(0, 0, 0, 22),
        BorderSizePixel = 0,
        BackgroundColor3 = fillColor,
    })
    local FillStroke = New("UIStroke", {Parent = Fill, Color = strokeColor})
    New("UICorner", {Parent = Fill})
    local ValueLabel = New("TextLabel", {
        Parent = Fill, RichText = true,
        TextColor3 = Color3.new(1, 1, 1),
        Text = formatVal(default),
        TextXAlignment = Enum.TextXAlignment.Right,
        TextSize = 22, Name = "Value",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -8, 0.5, 0),
        AnchorPoint = Vector2.new(1, 0.5),
        Size = UDim2.new(0, 80, 0, 24), ZIndex = 2,
    })
    local ClickArea = New("ImageButton", {
        Parent = Track,
        Size = UDim2.new(1, 0, 1, 0), 
        BackgroundTransparency = 1, ZIndex = 3,
    })
    New("TextLabel", {
        Parent = Container, RichText = true,
        TextColor3 = Color3.fromRGB(141, 141, 141),
        Text = description,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 13, Name = "description",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.3119, 0, 0.633, -4),
        Size = UDim2.new(0, 615, 0, 20), ZIndex = 2,
    })
    New("TextLabel", {
        Parent = Container, RichText = true,
        TextColor3 = Color3.new(1, 1, 1), Text = name,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 26, Name = "name",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.3119, 0, 0.233, -2),
        Size = UDim2.new(0, 615, 0, 24), ZIndex = 2,
    })

    local currentValue = default
    local maxWidth = 259

    local function setValue(val)
        val = math.clamp(val, min, max)
        val = snapToStep(val)
        val = math.clamp(val, min, max)
        currentValue = val
        local percent = (max - min) > 0 and ((currentValue - min) / (max - min)) or 0
        Fill.Size = UDim2.new(0, maxWidth * percent, 0, 22)
        ValueLabel.Text = formatVal(currentValue)
        local ok, err = pcall(callback, currentValue)
        if not ok then print()("[SWAG SUS]:", err) end
    end

    setValue(default)

    local dragging = false
    ClickArea.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local mouseX = input.Position.X
            local trackX = Track.AbsolutePosition.X
            local percent = math.clamp((mouseX - trackX) / Track.AbsoluteSize.X, 0, 1)
            local newVal = min + (max - min) * percent
            setValue(newVal)
        end
    end)

    return {
        Set = function(_, v) setValue(v) end,
        Get = function() return currentValue end,
        SetColor = function(_, c)
            fillColor = Darken(c, 0.12)
            strokeColor = Lighten(c, 0.3)
            Fill.BackgroundColor3 = fillColor
            FillStroke.Color = strokeColor
        end,
    }
end

function Library:CreateToggle(opts)
    opts = opts or {}
    local name = opts.Name or "Toggle"
    local description = opts.Description or ""
    local default = opts.Default or false
    local callback = opts.Callback or function() end
    local key = opts.Key

    local Container = New("Frame", {
        Parent = self.Scroll,
        Size = UDim2.new(0, 917, 0, 60),
        BackgroundTransparency = 1, Name = "Toggle",
    })
    local BG = New("Frame", {
        Parent = Container,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0, 400, 0.494, 1),
        Size = UDim2.new(0, 800, 0, 56),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(32, 32, 32),
    })
    New("UICorner", {Parent = BG})
    local ToggleBox = New("Frame", {
        Parent = Container, Name = "Toggle",
        Position = UDim2.new(0.0164, 0, 0.333, 0),
        Size = UDim2.new(0, 68, 0, 22),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(24, 25, 30),
    })
    New("UICorner", {Parent = ToggleBox})
    New("UIStroke", {Parent = ToggleBox, Color = Color3.fromRGB(85, 85, 85)})
    local Knob = New("Frame", {
        Parent = ToggleBox,
        Position = UDim2.new(-0.004, 0, 0, 0),
        Size = UDim2.new(0, 32, 0, 22),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(134, 0, 0),
    })
    New("UICorner", {Parent = Knob})
    local KnobStroke = New("UIStroke", {Parent = Knob, Color = Color3.fromRGB(188, 0, 0)})
    local ClickBtn = New("ImageButton", {
        Parent = ToggleBox,
        BackgroundTransparency = 1,
        Position = UDim2.new(-0.015, 0, -0.455, 0),
        Size = UDim2.new(0, 69, 0, 42),
    })
    New("TextLabel", {
        Parent = Container, RichText = true,
        TextColor3 = Color3.fromRGB(141, 141, 141),
        Text = description,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 13, Name = "description",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.1036, 0, 0.583, -4),
        Size = UDim2.new(0, 615, 0, 20), ZIndex = 2,
    })
    New("TextLabel", {
        Parent = Container, RichText = true,
        TextColor3 = Color3.new(1, 1, 1), Text = name,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 26, Name = "name",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.1036, 0, 0.183, -2),
        Size = UDim2.new(0, 615, 0, 24), ZIndex = 2,
    })
    local KeyBox = New("Frame", {
        Parent = Container, Size = UDim2.new(0, 50, 0, 42),
        Name = "Key",
        Position = UDim2.new(0.7995, 0, 0.160, 0),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(28, 30, 35),
        ZIndex = 6, Visible = key ~= nil,
    })
    local KeyText = New("TextBox", {
        Parent = KeyBox, RichText = true,
        TextColor3 = Color3.new(1, 1, 1),
        Text = key or "",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1, TextSize = 18,
        Size = UDim2.new(0, 47, 0, 42),
        ZIndex = 6, ClearTextOnFocus = false,
    })
    New("UICorner", {Parent = KeyBox})
    New("UIStroke", {Parent = KeyBox, Color = Color3.fromRGB(85, 85, 85)})

    local state = default
    local function updateVisual()
        if state then
            Tween(Knob, 0.15, {
                Position = UDim2.new(0.526, 0, 0, 0),
                BackgroundColor3 = Color3.fromRGB(0, 134, 0),
            })
            Tween(KnobStroke, 0.15, {Color = Color3.fromRGB(0, 188, 0)})
        else
            Tween(Knob, 0.15, {
                Position = UDim2.new(-0.004, 0, 0, 0),
                BackgroundColor3 = Color3.fromRGB(134, 0, 0),
            })
            Tween(KnobStroke, 0.15, {Color = Color3.fromRGB(188, 0, 0)})
        end
    end
    local function setState(v)
        state = v
        updateVisual()
        local ok, err = pcall(callback, state)
        if not ok then Print("[SWAG Sus]:", err) end
    end

    updateVisual()
    if default then
        spawn(function() pcall(callback, true) end)
    end

    ClickBtn.MouseButton1Click:Connect(function() setState(not state) end)

    local currentKey = key
    KeyText.Focused:Connect(function() KeyText.Text = "..." end)
    KeyText:GetPropertyChangedSignal("Text"):Connect(function()
        if KeyText.Text ~= "..." and #KeyText.Text > 0 then
            currentKey = KeyText.Text:upper():sub(1,1)
            KeyText.Text = currentKey
        end
    end)
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.UserInputType == Enum.UserInputType.Keyboard and currentKey then
            if input.KeyCode.Name:upper() == currentKey:upper() then
                setState(not state)
            end
        end
    end)

    return {
        Set = function(_, v) setState(v) end,
        Get = function() return state end,
        Toggle = function() setState(not state) end,
    }
end

function Library:CreateSubtitle(opts)
    if type(opts) == "string" then opts = {Name = opts} end
    opts = opts or {}
    local name = opts.Name or "Subtitle"

    local Container = New("Frame", {
        Parent = self.Scroll, Name = "Subtitle",
        Size = UDim2.new(0, 917, 0, 56),
        BackgroundTransparency = 1,
    })
    local BG = New("Frame", {
        Parent = Container,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0, 400, 0.494, 1),
        Size = UDim2.new(0, 800, 0, 46),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(32, 32, 32),
    })
    New("UICorner", {Parent = BG})
    local Label = New("TextLabel", {
        Parent = Container, RichText = true,
        TextColor3 = Color3.new(1, 1, 1), Text = name,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 26, Name = "name",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.0153, 0, 0.327, -2),
        Size = UDim2.new(0, 869, 0, 24), ZIndex = 2,
    })

    return {
        SetText = function(_, t) name = t; Label.Text = t end,
    }
end

function Library:CreateTextBox(opts)
    opts = opts or {}
    local name = opts.Name or "TextBox"
    local description = opts.Description or ""
    local placeholder = opts.Placeholder or opts.Default or ""
    local callback = opts.Callback or function() end

    local Container = New("Frame", {
        Parent = self.Scroll, Name = "TextBox",
        Size = UDim2.new(0, 917, 0, 60),
        BackgroundTransparency = 1,
    })
    local BG = New("Frame", {
        Parent = Container,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0, 400, 0.494, 1),
        Size = UDim2.new(0, 800, 0, 56),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(32, 32, 32),
    })  
    New("UICorner", {Parent = BG})
    local Box = New("Frame", {
        Parent = Container, Name = "TextBox",
        Position = UDim2.new(0.0164, 0, 0.15, 0),
        Size = UDim2.new(0, 68, 0, 42),
        BorderSizePixel = 0,
        BackgroundColor3 = Color3.fromRGB(24, 25, 30),
    })
    New("UICorner", {Parent = Box})
    New("UIStroke", {Parent = Box, Color = Color3.fromRGB(85, 85, 85)})
    local Input = New("TextBox", {
        Parent = Box, RichText = true,
        TextColor3 = Color3.new(1, 1, 1),
        Text = placeholder,
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1, TextSize = 14,
        Size = UDim2.new(0, 68, 0, 42),
        ZIndex = 6, ClearTextOnFocus = false,
    })
    New("TextLabel", {
        Parent = Container, RichText = true,
        TextColor3 = Color3.new(1, 1, 1), Text = name,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 26, Name = "name",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.1036, 0, 0.183, -2),
        Size = UDim2.new(0, 615, 0, 24), ZIndex = 2,
    })
    New("TextLabel", {
        Parent = Container, RichText = true,
        TextColor3 = Color3.fromRGB(141, 141, 141),
        Text = description,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 13, Name = "description",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.1036, 0, 0.583, -4),
        Size = UDim2.new(0, 615, 0, 20), ZIndex = 2,
    })

    local currentText = placeholder

    Input.Focused:Connect(function()
        if Input.Text == placeholder then Input.Text = "" end
    end)
    Input.FocusLost:Connect(function(enterPressed)
        currentText = Input.Text
        if currentText == "" then
            Input.Text = placeholder
        end
        local ok, err = pcall(callback, currentText, enterPressed)
        if not ok then end
    end)

    return {
        SetText = function(_, t) currentText = t; Input.Text = t end,
        GetText = function() return currentText end,
    }
end

return Library 
end)()
