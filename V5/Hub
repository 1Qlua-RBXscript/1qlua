LocalTab:CreateToggle({
    Name = "Noclip",
    Description = "Проходить сквозь стены",
    Default = false,
    Callback = function(state)
        if state then
            _G.noclip = true
            game:GetService("RunService"):BindToRenderStep("noclip", 1, function()
                if _G.noclip then
                    local char = game.Players.LocalPlayer.Character
                    if char then
                        for _, v in pairs(char:GetDescendants()) do
                            if v:IsA("BasePart") and v.CanCollide then
                                v.CanCollide = false
                            end
                        end
                    end
                end
            end)
        else
            _G.noclip = false
            pcall(function()
                game:GetService("RunService"):UnbindFromRenderStep("noclip")
            end)
        end
    end
})

