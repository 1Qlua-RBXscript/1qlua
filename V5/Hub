local function start()
    UI.Enabled = true
    notificationContainer.Visible = true
    toastsContainer.Visible = true
    smartBar.Visible = true
    toggle.Visible = true
    addCustomButton("Settings", {
        image1 = 9753762469,
        image2 = 9753762469,
        color1 = Color3.fromRGB(211, 141, 55),
        color2 = Color3.fromRGB(0, 170, 127),
        script1 = function()
            Window:Close()
        end,
        script2 = function()
            Window:Open()
        end
    })

    task.spawn(function()
        while UI.Enabled do
            if smartBar and smartBar:FindFirstChild("Time") then
                smartBar.Time.Text = os.date("%H") .. ":" .. os.date("%M")
            end
            task.wait(1)
        end
    end)
end

start()

