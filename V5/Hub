        Position = UDim2.new(0.3119, 0, 0.633, -4),
        Size = UDim2.new(0, 615, 0, 20),
        ZIndex = 2,
    })
    New("TextLabel", {
        Parent = Container,
        RichText = true,
        TextColor3 = Color3.new(1, 1, 1),
        Text = name,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 26,
        Name = "name",
        Font = Enum.Font.SourceSansBold,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.3119, 0, 0.233, -2),
        Size = UDim2.new(0, 615, 0, 24),
        ZIndex = 2,
    })
    
    local currentValue = default
    local maxWidth = 259
    
    local function setValue(val)
        val = math.clamp(val, min, max)
        currentValue = math.floor(val + 0.5)
        local percent = (currentValue - min) / (max - min)
        Fill.Size = UDim2.new(0, maxWidth * percent, 0, 22)
        ValueLabel.Text = tostring(currentValue)
        local ok, err = pcall(callback, currentValue)
        if not ok then warn("[1qluaLib Slider Error]:", err) end
    end
    
    setValue(default)
    
    local dragging = false
    ClickArea.MouseButton1Down:Connect(function()
        dragging = true
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local mouseX = input.Position.X
            local trackX = Track.AbsolutePosition.X
            local percent = math.clamp((mouseX - trackX) / Track.AbsoluteSize.X, 0, 1)
            local newVal = min + (max - min) * percent
            setValue(newVal)
        end
    end)
    
    return {
        Set = function(_, v) setValue(v) end,
        Get = function() return currentValue end,
    }
end

