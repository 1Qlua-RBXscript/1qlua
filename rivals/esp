local function setupColorInput(inputBox, key, visualFrames)
    inputBox.FocusLost:Connect(function()
        local r, g, b = inputBox.Text:match("(%d+)[%s,]+(%d+)[%s,]+(%d+)")
        if r and g and b then
            local color = Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b))
            Config.Colors[key] = color
            for _, f in pairs(visualFrames) do f.BackgroundColor3 = color end
            saveSettings()
        end
    end)
end

