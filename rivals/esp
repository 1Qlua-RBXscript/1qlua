local function UpdateList(filter)
    for _, v in pairs(Scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if filter and not p.Name:lower():find(filter:lower()) then continue end
        
        local Card = Instance.new("TextButton", Scroll)
        Card.Size = UDim2.new(1, 0, 0, 35)
        Card.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        Card.Text = ""
        Instance.new("UICorner", Card)

        local Icon = Instance.new("ImageLabel", Card)
        Icon.Size = UDim2.new(0, 25, 0, 25)
        Icon.Position = UDim2.new(0, 5, 0, 5)
        task.spawn(function()
            Icon.Image = Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
        end)
        Instance.new("UICorner", Icon).CornerRadius = UDim.new(0, 5)

        local DName = Instance.new("TextLabel", Card)
        DName.Text = p.DisplayName
        DName.Position = UDim2.new(0.16, 0, 0.13, 0)
        DName.Size = UDim2.new(0.6, 0, 0, 20)
        DName.TextColor3 = Color3.fromRGB(200, 200, 200)
        DName.Font = "GothamBold"
        DName.TextSize = 14
        DName.TextXAlignment = "Left"
        DName.BackgroundTransparency = 1

        local Indicator = Instance.new("Frame", Card)
        Indicator.Size = UDim2.new(0, 7, 0, 20)
        Indicator.Position = UDim2.new(0.92, 0, 0.2, 0)
        local isOff = Settings.BlacklistedUsers[tostring(p.UserId)]
        Indicator.BackgroundColor3 = isOff and Color3.fromRGB(206, 131, 188) or Color3.fromRGB(0, 134, 9)
        Instance.new("UICorner", Indicator).CornerRadius = UDim.new(0, 5)

        Card.MouseButton1Click:Connect(function()
            local id = tostring(p.UserId)
            Settings.BlacklistedUsers[id] = not Settings.BlacklistedUsers[id] or nil
            Indicator.BackgroundColor3 = Settings.BlacklistedUsers[id] and Color3.fromRGB(206, 131, 188) or Color3.fromRGB(0, 134, 9)
            SaveData()
        end)
    end
end
