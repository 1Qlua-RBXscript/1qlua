        {"Torso", "Left Leg", "Legs"}, {"Torso", "Right Leg", "Legs"}
    }
}

local function addESP(p)
    if p == Players.LocalPlayer then return end
    local assets = { 
        Lines = {}, 
        HeadImg = Instance.new("ImageLabel", SkeletonStudioConfig),
        AvatarImg = Instance.new("ImageLabel", SkeletonStudioConfig),
        HpText = Drawing.new("Text"),
        HpBarBg = Drawing.new("Square"),
        HpBarFill = Drawing.new("Square")
    }
    assets.HeadImg.BackgroundTransparency = 1
    assets.HeadImg.AnchorPoint = Vector2.new(0.5, 0.5)
    assets.HeadImg.Image = Config.HeadImage
    assets.HeadImg.Visible = false
    assets.HeadImg.ZIndex = 100
    
    assets.AvatarImg.BackgroundTransparency = 1
    assets.AvatarImg.AnchorPoint = Vector2.new(0.5, 0.5)
    assets.AvatarImg.Size = UDim2.new(0, 50, 0, 50)
    assets.AvatarImg.Visible = false
    assets.AvatarImg.ZIndex = 90
    task.spawn(function()
        local s, img = pcall(function()
            return Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
        end)
        if s and img and assets.AvatarImg then
            assets.AvatarImg.Image = img
        end
    end)
    
    assets.HpText.Visible = false
    assets.HpText.Color = Color3.fromRGB(255, 255, 255)
    assets.HpText.Outline = true
    assets.HpText.OutlineColor = Color3.new(0,0,0)
    assets.HpText.Size = 14
    assets.HpText.Center = true
    
    assets.HpBarBg.Visible = false
    assets.HpBarBg.Color = Color3.fromRGB(40, 40, 40)
    assets.HpBarBg.Filled = true
    assets.HpBarBg.Thickness = 1
    assets.HpBarBg.Transparency = 0.1
    
    assets.HpBarFill.Visible = false
    assets.HpBarFill.Filled = true
    assets.HpBarFill.Thickness = 0
    
    for i = 1, 12 do
        local l = Drawing.new("Line")
        l.Visible = false
        l.Transparency = 1
        l.ZIndex = 1
        table.insert(assets.Lines, l)
    end
    Storage[p] = assets
end

for _, p in pairs(Players:GetPlayers()) do addESP(p) end
Players.PlayerAdded:Connect(addESP)

local AVATAR_OFFSET = Vector3.new(0, -2.5, 0)
local HP_OFFSET = Vector3.new(0, 9, 0)
local BAR_WIDTH = 60
local BAR_HEIGHT = 1

RunService.RenderStepped:Connect(function()
    local cam = workspace.CurrentCamera
    for player, assets in pairs(Storage) do
        local char = player.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local head = char and char:FindFirstChild("Head")
        
        if Config.Enabled and not Blacklist[player.UserId] and head and hum and hum.Health > 0 then
            local headPos, onScreen = cam:WorldToViewportPoint(head.Position)
            local dist = (head.Position - cam.CFrame.Position).Magnitude
            
            if onScreen and dist < Config.MaxDist then
                local hSize = (2500 / dist) * Config.HeadScale
                assets.HeadImg.Size = UDim2.new(0, hSize, 0, hSize)
                assets.HeadImg.Position = UDim2.new(0, headPos.X, 0, headPos.Y)
                assets.HeadImg.Visible = true
                
                local rootPart = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
                if rootPart then
                    local footPos = rootPart.Position + AVATAR_OFFSET
                    local footPosVec, footOnScreen = cam:WorldToViewportPoint(footPos)
                    if footOnScreen then
                        local avatarSize = (1500 / dist) * Config.HeadScale
                        assets.AvatarImg.Size = UDim2.new(0, avatarSize, 0, avatarSize)
                        assets.AvatarImg.Position = UDim2.new(0, footPosVec.X, 0, footPosVec.Y)
                        assets.AvatarImg.Visible = true
                        
                        local hpPos = footPos + HP_OFFSET
                        local hpVec, hpOn = cam:WorldToViewportPoint(hpPos)
                        if hpOn then
                            local healthPercent = hum.Health / hum.MaxHealth
                            local barColor = Color3.fromRGB(255 - 255 * healthPercent, 255 * healthPercent, 0)
                            local textX = hpVec.X 
                            local textY = hpVec.Y
                            assets.HpText.Text = string.format("%.0f%%", healthPercent * 100)
                            assets.HpText.Position = Vector2.new(textX, textY)
                            assets.HpText.Visible = true
                            
                            local barX = textX - BAR_WIDTH/2
                            local barY = textY + 16
                            assets.HpBarBg.Position = Vector2.new(barX, barY)
                            assets.HpBarBg.Size = Vector2.new(BAR_WIDTH, BAR_HEIGHT)
                            assets.HpBarBg.Visible = true
                            
                            assets.HpBarFill.Position = Vector2.new(barX, barY)
                            assets.HpBarFill.Size = Vector2.new(BAR_WIDTH * healthPercent, BAR_HEIGHT)
                            assets.HpBarFill.Color = barColor
                            assets.HpBarFill.Visible = true
                        else
                            assets.HpText.Visible = false
                            assets.HpBarBg.Visible = false
                            assets.HpBarFill.Visible = false
                        end
                    else
                        assets.AvatarImg.Visible = false
                        assets.HpText.Visible = false
                        assets.HpBarBg.Visible = false
                        assets.HpBarFill.Visible = false
                    end
                else
                    assets.AvatarImg.Visible = false
                    assets.HpText.Visible = false
                    assets.HpBarBg.Visible = false
                    assets.HpBarFill.Visible = false
                end
                
                local rig = hum.RigType == Enum.HumanoidRigType.R15 and Bones.R15 or Bones.R6
                for i, bone in ipairs(rig) do
                    local p1, p2 = char:FindFirstChild(bone[1]), char:FindFirstChild(bone[2])
                    local line = assets.Lines[i]
                    if p1 and p2 and line then
                        local pos1, vis1 = cam:WorldToViewportPoint(p1.Position)
                        local pos2, vis2 = cam:WorldToViewportPoint(p2.Position)
                        if vis1 and vis2 then
                            line.Visible = true
                            line.From = Vector2.new(pos1.X, pos1.Y)
                            line.To = Vector2.new(pos2.X, pos2.Y)
                            line.Color = Config.Colors[bone[3]]
                            line.Thickness = Config.Thickness
                        else line.Visible = false end
                    elseif line then line.Visible = false end
                end
            else
                assets.HeadImg.Visible = false
                assets.AvatarImg.Visible = false
                assets.HpText.Visible = false
                assets.HpBarBg.Visible = false
                assets.HpBarFill.Visible = false
                for _, l in pairs(assets.Lines) do l.Visible = false end
            end
        else
            assets.HeadImg.Visible = false
            assets.AvatarImg.Visible = false
            assets.HpText.Visible = false
            assets.HpBarBg.Visible = false
            assets.HpBarFill.Visible = false
            for _, l in pairs(assets.Lines) do l.Visible = false end
        end
    end
end)

