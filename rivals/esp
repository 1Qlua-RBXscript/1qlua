    MenuKey = Enum.KeyCode.P,
    ToggleKey = Enum.KeyCode.Q,
    HeadKey = Enum.KeyCode.Z
}

local function SaveData()
    local data = {
        Radius = Settings.Radius, 
        BlacklistedUsers = Settings.BlacklistedUsers,
        OnlyHead = Settings.OnlyHead
    }
    if writefile then writefile(FILE_NAME, HttpService:JSONEncode(data)) end
end

if isfile and isfile(FILE_NAME) then
    local s, r = pcall(function() return HttpService:JSONDecode(readfile(FILE_NAME)) end)
    if s and r then
        Settings.Radius = r.Radius or 20
        Settings.BlacklistedUsers = r.BlacklistedUsers or {}
        Settings.OnlyHead = r.OnlyHead or false
    end
end

