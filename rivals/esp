local function saveSettings()
    if not writefile then 
        return 
    end
    if not Config then
        return
    end
    local settings = {
        Enabled = Config.Enabled,
        HeadImage = Config.HeadImage,
        HeadScale = Config.HeadScale,
        Thickness = Config.Thickness,
        MaxDist = Config.MaxDist,
        Colors = {
            Head = { Config.Colors.Head.R * 255, Config.Colors.Head.G * 255, Config.Colors.Head.B * 255 },
            Torso = { Config.Colors.Torso.R * 255, Config.Colors.Torso.G * 255, Config.Colors.Torso.B * 255 },
            Arms = { Config.Colors.Arms.R * 255, Config.Colors.Arms.G * 255, Config.Colors.Arms.B * 255 },
            Legs = { Config.Colors.Legs.R * 255, Config.Colors.Legs.G * 255, Config.Colors.Legs.B * 255 }
        }
    }
    local data = HttpService:JSONEncode(settings)
    local success, err = pcall(writefile, SETTINGS_FILE, data)
    if not success then
    end
end

local function loadSettings()
    if not readfile then 
        return 
    end
    local success, data = pcall(readfile, SETTINGS_FILE)
    if success and data and data ~= "" then
        local loaded = HttpService:JSONDecode(data)
        if type(loaded) == "table" then
            Config.Enabled = loaded.Enabled
            Config.HeadImage = loaded.HeadImage or Config.HeadImage
            Config.HeadScale = loaded.HeadScale or 1
            Config.Thickness = loaded.Thickness or 1
            Config.MaxDist = loaded.MaxDist or 1500
            if loaded.Colors then
                if loaded.Colors.Head then Config.Colors.Head = Color3.fromRGB(unpack(loaded.Colors.Head)) end
                if loaded.Colors.Torso then Config.Colors.Torso = Color3.fromRGB(unpack(loaded.Colors.Torso)) end
                if loaded.Colors.Arms then Config.Colors.Arms = Color3.fromRGB(unpack(loaded.Colors.Arms)) end
                if loaded.Colors.Legs then Config.Colors.Legs = Color3.fromRGB(unpack(loaded.Colors.Legs)) end
            end
        end
    else
    end
end

local function saveBlacklist()
    if not writefile then return end
    local data = HttpService:JSONEncode(Blacklist)
    local success, err = pcall(writefile, BLACKLIST_FILE, data)
    if not success then
    end
end

local function loadBlacklist()
    if not readfile then return end
    local success, data = pcall(readfile, BLACKLIST_FILE)
    if success and data and data ~= "" then
        local decoded = HttpService:JSONDecode(data)
        if type(decoded) == "table" then
            for k, v in pairs(decoded) do
                Blacklist[tonumber(k) or k] = v
            end
        end
    end
end

