local function UpdatePlayerList()
    for _, p in pairs(Players:GetPlayers()) do
        if p == Players.LocalPlayer then continue end
        local uid = p.UserId
        
        if not PlayerList:FindFirstChild(tostring(uid)) then
            local card = SamplePlayer:Clone()
            card.Visible = true
            card.Name = tostring(uid)
            card:FindFirstChild("Username").Text = "@" .. p.Name
            card:FindFirstChild("DisplayName").Text = p.DisplayName
            
            task.spawn(function()
                local s, img = pcall(function()
                    return Players:GetUserThumbnailAsync(uid, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
                end)
                if s and img then
                    local ic = card:FindFirstChild("icon")
                    if ic then ic.Image = img end
                end
            end)
            
            local pInd = card:FindFirstChild("indicator")
            pInd.BackgroundColor3 = Blacklist[uid] and COLOR_OFF or COLOR_ON
            
            card.MouseButton1Click:Connect(function()
                Blacklist[uid] = not Blacklist[uid]
                pInd.BackgroundColor3 = Blacklist[uid] and COLOR_OFF or COLOR_ON
                saveBlacklist()
            end)
            
            card.Parent = PlayerList
        end
    end
end

Players.PlayerAdded:Connect(UpdatePlayerList)
Players.PlayerRemoving:Connect(function(p)
    local card = PlayerList:FindFirstChild(tostring(p.UserId))
    if card then card:Destroy() end
    if Storage[p] then
        if Storage[p].HeadImg then Storage[p].HeadImg:Destroy() end
        if Storage[p].AvatarImg then Storage[p].AvatarImg:Destroy() end
        if Storage[p].HpText then Storage[p].HpText:Remove() end
        if Storage[p].HpBarBg then Storage[p].HpBarBg:Remove() end
        if Storage[p].HpBarFill then Storage[p].HpBarFill:Remove() end
        for _, l in pairs(Storage[p].Lines or {}) do l:Remove() end
        Storage[p] = nil
    end
end)
UpdatePlayerList()

