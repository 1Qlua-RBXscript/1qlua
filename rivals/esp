local AllHitboxes = {"HitboxBody", "HitboxBodySmall", "HitboxHead", "HitboxHeadSmall", "HumanoidRootPart", "PhysicalHitboxHead"}
local HeadHitboxes = {"HitboxHead", "HitboxHeadSmall", "PhysicalHitboxHead"}
local isLeftClicking = false

local function IsPlayerVisible(targetChar, targetPart)
    local origin = Camera.CFrame.Position
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    
    local result = workspace:Raycast(origin, targetPart.Position - origin, params)
    return result and (result.Instance:IsDescendantOf(targetChar) or result.Instance == targetPart)
end

UserInputService.InputBegan:Connect(function(i, gp)
    if gp then return end
    if i.KeyCode == Settings.ToggleKey then
        Settings.Enabled = not Settings.Enabled
        UpdateDots()
        if not Settings.Enabled then
            if MainFrame.Visible then
                MainFrame.Visible = false
                Settings.MenuOpen = false
            end
        end
    elseif i.KeyCode == Settings.HeadKey then
        Settings.OnlyHead = not Settings.OnlyHead
        HeadToggle.Text = "Head Only: "..(Settings.OnlyHead and "ON" or "OFF")
        UpdateDots()
    elseif i.KeyCode == Settings.MenuKey then
        Settings.MenuOpen = not Settings.MenuOpen
        MainFrame.Visible = Settings.MenuOpen
        if Settings.MenuOpen then UpdateList() end
    end
end)

RunService.RenderStepped:Connect(function()
    if not Settings.Enabled then
        if isLeftClicking then vim:SendMouseButtonEvent(0, 0, 0, false, game, 1) isLeftClicking = false end
        return
    end

    local center = Camera.ViewportSize / 2
    local activeHitboxes = Settings.OnlyHead and HeadHitboxes or AllHitboxes
    local targetFound = false

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and not Settings.BlacklistedUsers[tostring(p.UserId)] then
            for _, name in pairs(activeHitboxes) do
                local part = p.Character:FindFirstChild(name)
                if part then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                        if dist <= Settings.Radius and IsPlayerVisible(p.Character, part) then
                            targetFound = true break
                        end
                    end
                end
            end
        end
        if targetFound then break end
    end

    local m = UserInputService:GetMouseLocation()
    if targetFound then
        if not isLeftClicking then
            vim:SendMouseButtonEvent(m.X, m.Y, 0, true, game, 1)
            isLeftClicking = true
        end
    elseif isLeftClicking then
        vim:SendMouseButtonEvent(m.X, m.Y, 0, false, game, 1)
        isLeftClicking = false
    end
end)

UpdateList()
