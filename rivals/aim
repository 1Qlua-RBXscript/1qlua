local HttpService = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local Config = {
    AimActive = false,
    MenuOpen = true,
    Smoothness = 1,
    FOVRadius = 300,
    AimKey = Enum.KeyCode.K,
    MenuKey = Enum.KeyCode.P,
    Mode = "Clamp",
    FileName = "1Qlua_Ultimate_Config.json"
}

local Blacklist = {}
local BindingTarget = nil 

local function Save()
    if writefile then
        writefile(Config.FileName, HttpService:JSONEncode({
            Blacklist = Blacklist, 
            Mode = Config.Mode,
            AimKey = Config.AimKey.Name,
            MenuKey = Config.MenuKey.Name
        }))
    end
end

