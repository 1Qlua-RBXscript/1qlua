
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local Config = {
    AimbotKey = Enum.KeyCode.K,
    MenuKey = Enum.KeyCode.P,
    SaveFile = "Aimbot_Ignored.json",
    Ignored = {},
    AimbotActive = false
}

local function SaveData()
    if writefile then
        writefile(Config.SaveFile, HttpService:JSONEncode(Config.Ignored))
    end
end

local function LoadData()
    if isfile and isfile(Config.SaveFile) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(Config.SaveFile)) end)
        if success then Config.Ignored = data end
    end
end
LoadData()

local function GetClosestPlayer()
    local closest = nil
    local dist = math.huge
    local mousePos = UIS:GetMouseLocation()

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") and not Config.Ignored[p.Name] then
            local pos, onScreen = Camera:WorldToViewportPoint(p.Character.Head.Position)
            if onScreen then
                local magnitude = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                if magnitude < dist then
                    closest = p
                    dist = magnitude
                end
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    if Config.AimbotActive then
        local target = GetClosestPlayer()
        if target and target.Character then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Character.Head.Position)
        end
    end
end)

local function GetGuiParent()
    if gethui then return gethui() end
    if game:GetService("CoreGui"):FindFirstChild("RobloxGui") then return game:GetService("CoreGui").RobloxGui end
    return LocalPlayer:WaitForChild("PlayerGui")
end

local function GenerateName()
    local n = ""
    for i = 1, 12 do n = n .. string.char(math.random(97, 122)) end
    return n
end

local MainGui = Instance.new("ScreenGui")
MainGui.Name = GenerateName()
MainGui.Parent = GetGuiParent()

