local function UpdateList()
    for _, v in pairs(PlayerList:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        
        local Card = Instance.new("TextButton", PlayerList)
        Card.Size = UDim2.new(1, 0, 0, 35)
        Card.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        Card.Text = ""
        Instance.new("UICorner", Card)

        -- ИСПРАВЛЕННЫЕ АВАТАРКИ (ПОЛУЧЕНИЕ РЕАЛЬНОГО ФОТО)
        local Icon = Instance.new("ImageLabel", Card)
        Icon.Size = UDim2.new(0, 25, 0, 25)
        Icon.Position = UDim2.new(0, 5, 0, 5)
        Icon.BackgroundColor3 = Color3.fromRGB(30,30,30)
        
        task.spawn(function()
            local content, isReady = Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
            Icon.Image = content
        end)
        Instance.new("UICorner", Icon).CornerRadius = UDim.new(0, 5)

        local DName = Instance.new("TextLabel", Card)
        DName.Text = p.DisplayName
        DName.Position = UDim2.new(0.16, 0, 0.13, 0)
        DName.Size = UDim2.new(0.6, 0, 0, 20)
        DName.TextColor3 = Color3.fromRGB(200, 200, 200)
        DName.Font = Enum.Font.GothamBold -- ЖИРНЫЙ
        DName.TextXAlignment = "Left"
        DName.BackgroundTransparency = 1
        DName.TextSize = 14

        local UName = Instance.new("TextLabel", Card)
        UName.Text = "@"..p.Name
        UName.Position = UDim2.new(0.16, 0, 0.65, 0)
        UName.Size = UDim2.new(0.6, 0, 0, 10)
        UName.TextColor3 = Color3.fromRGB(127, 127, 127)
        UName.Font = Enum.Font.GothamBold
        UName.TextSize = 10
        UName.TextXAlignment = "Left"
        UName.BackgroundTransparency = 1

        local Indicator = Instance.new("Frame", Card)
        Indicator.Size = UDim2.new(0, 7, 0, 20)
        Indicator.Position = UDim2.new(0.92, 0, 0.2, 0)
        Indicator.BackgroundColor3 = Blacklist[tostring(p.UserId)] and Color3.fromRGB(206, 131, 188) or Color3.fromRGB(0, 134, 9)
        Instance.new("UICorner", Indicator).CornerRadius = UDim.new(0, 5)

        Card.MouseButton1Click:Connect(function()
            local id = tostring(p.UserId)
            Blacklist[id] = not Blacklist[id]
            Indicator.BackgroundColor3 = Blacklist[id] and Color3.fromRGB(206, 131, 188) or Color3.fromRGB(0, 134, 9)
            Save()
        end)
    end
end

AimBtn.MouseButton1Click:Connect(function() BindingTarget = "Aim" AimBtn.Text = "Aim Key: ..." end)
MenuBtn.MouseButton1Click:Connect(function() BindingTarget = "Menu" MenuBtn.Text = "Menu Key: ..." end)
ModeBtn.MouseButton1Click:Connect(function()
    Config.Mode = (Config.Mode == "Clamp") and "sticking" or "Clamp"
    ModeBtn.Text = "Mode: " .. Config.Mode
    Save()
end)

UserInputService.InputBegan:Connect(function(input, proc)
    if BindingTarget and input.UserInputType == Enum.UserInputType.Keyboard then
        if BindingTarget == "Aim" then
            Config.AimKey = input.KeyCode
            AimBtn.Text = "Aim Key: " .. input.KeyCode.Name
        else
            Config.MenuKey = input.KeyCode
            MenuBtn.Text = "Menu Key: " .. input.KeyCode.Name
        end
        BindingTarget = nil
        Save()
        return
    end
    if proc then return end
    if input.KeyCode == Config.MenuKey then
        Config.MenuOpen = not Config.MenuOpen
        MainFrame.Visible = Config.MenuOpen
        if Config.MenuOpen then UpdateList() end
    elseif input.KeyCode == Config.AimKey and Config.Mode == "sticking" then
        Config.AimActive = not Config.AimActive
    end
end)

RunService.RenderStepped:Connect(function()
    local isAiming = (Config.Mode == "Clamp" and UserInputService:IsKeyDown(Config.AimKey)) or (Config.Mode == "sticking" and Config.AimActive)
    if isAiming then
        local target, dist = nil, Config.FOVRadius
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") and not Blacklist[tostring(p.UserId)] then
                local pos, vis = Camera:WorldToViewportPoint(p.Character.Head.Position)
                if vis then
                    local mag = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                    if mag < dist then dist = mag target = p end
                end
            end
        end
        if target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Character.Head.Position), Config.Smoothness)
        end
    end
end)

UpdateList()
