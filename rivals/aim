-- Список игроков
local List = Instance.new("ScrollingFrame")
List.Size = UDim2.new(0.9, 0, 0.75, 0)
List.Position = UDim2.new(0.05, 0, 0.15, 0)
List.BackgroundTransparency = 1
List.CanvasSize = UDim2.new(0, 0, 0, 0)
List.ScrollBarThickness = 2
List.Parent = Frame

local Layout = Instance.new("UIListLayout")
Layout.Padding = UDim.new(0, 5)
Layout.Parent = List

local function UpdateList()
    for _, child in pairs(List:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -5, 0, 25)
            btn.Text = p.Name
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 12
            
            if Config.Ignored[p.Name] then
                btn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
                btn.Text = p.Name .. " [OFF]"
            else
                btn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
                btn.Text = p.Name .. " [ON]"
            end
            
            btn.TextColor3 = Color3.new(1, 1, 1)
            btn.Parent = List
            
            local bCorner = Instance.new("UICorner")
            bCorner.CornerRadius = UDim.new(0, 4)
            bCorner.Parent = btn

            btn.MouseButton1Click:Connect(function()
                if Config.Ignored[p.Name] then
                    Config.Ignored[p.Name] = nil
                else
                    Config.Ignored[p.Name] = true
                end
                SaveData()
                UpdateList()
            end)
        end
    end
    List.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y)
end
UIS.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Config.AimbotKey then
        Config.AimbotActive = true
    elseif input.KeyCode == Config.MenuKey then
        Frame.Visible = not Frame.Visible
        if Frame.Visible then UpdateList() end
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.KeyCode == Config.AimbotKey then
        Config.AimbotActive = false
    end
end)

Players.PlayerAdded:Connect(UpdateList)
Players.PlayerRemoving:Connect(UpdateList)
