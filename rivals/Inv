local function ApplyAnimatedGradientStroke(parent)
    local UIStroke = Instance.new("UIStroke")
    UIStroke.Color = Color3.new(1, 1, 1)
    UIStroke.Thickness = 2
    UIStroke.Parent = parent

    local UIGradient = Instance.new("UIGradient")
    UIGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.new(0, 0, 0)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 162, 233)) 
    })
    UIGradient.Parent = UIStroke
    local ROTATION_SPEED = 90
    local currentRotation = 0
    RunService.RenderStepped:Connect(function(deltaTime)
        currentRotation = currentRotation + (ROTATION_SPEED * deltaTime)
        if currentRotation > 180 then
            currentRotation = -180
        elseif currentRotation < -180 then
            currentRotation = 180
        end
        UIGradient.Rotation = currentRotation
    end)
end

local function GetPlayerWeapon(username)
    local viewmodels = workspace:FindFirstChild("ViewModels")
    if viewmodels then
        for _, model in pairs(viewmodels:GetChildren()) do
            local splitName = string.split(model.Name, " - ")
            if splitName[1] == username and splitName[2] then
                return splitName[2]
            end
        end
    end
    return "None"
end
