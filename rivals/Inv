    Username.TextColor3 = Color3.fromRGB(127, 127, 127)
    Username.TextSize = 12
    Username.TextXAlignment = Enum.TextXAlignment.Left

    local isActive = false
    SamplePlayer.MouseButton1Click:Connect(function()
        isActive = not isActive
        if isActive then
            indicator.BackgroundColor3 = Color3.fromRGB(0, 134, 9)
            activeInfoPanels[player.Name] = CreateInformationPanel(player)
        else
            indicator.BackgroundColor3 = Color3.fromRGB(206, 131, 188)
            if activeInfoPanels[player.Name] then
                activeInfoPanels[player.Name]:Destroy()
                activeInfoPanels[player.Name] = nil
            end
        end
    end)
end

for _, player in ipairs(Players:GetPlayers()) do
    AddPlayerToList(player)
end

Players.PlayerAdded:Connect(AddPlayerToList)
Players.PlayerRemoving:Connect(function(player)
    if PlayerList:FindFirstChild(player.Name) then
        PlayerList[player.Name]:Destroy()
    end
    if activeInfoPanels[player.Name] then
        activeInfoPanels[player.Name]:Destroy()
        activeInfoPanels[player.Name] = nil
    end
end)

