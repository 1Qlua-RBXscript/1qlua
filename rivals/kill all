local function UpdatePlayerList()
    for _, child in ipairs(Scroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local Card = Instance.new("TextButton", Scroll)
        Card.Size = UDim2.new(1, 0, 0, 35)
        Card.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        Card.Text = ""
        Instance.new("UICorner", Card)

        local Icon = Instance.new("ImageLabel", Card)
        Icon.Size = UDim2.new(0, 25, 0, 25)
        Icon.Position = UDim2.new(0, 5, 0, 5)
        task.spawn(function()
            Icon.Image = Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
        end)
        Instance.new("UICorner", Icon).CornerRadius = UDim.new(0, 5)

        local DName = Instance.new("TextLabel", Card)
        DName.Text = player.DisplayName
        DName.Position = UDim2.new(0.16, 0, 0.13, 0)
        DName.Size = UDim2.new(0.6, 0, 0, 20)
        DName.TextColor3 = Color3.fromRGB(200, 200, 200)
        DName.Font = "GothamBold"
        DName.TextSize = 14
        DName.TextXAlignment = "Left"
        DName.BackgroundTransparency = 1

        local Indicator = Instance.new("Frame", Card)
        Indicator.Size = UDim2.new(0, 7, 0, 20)
        Indicator.Position = UDim2.new(0.92, 0, 0.2, 0)
        Indicator.BackgroundColor3 = (selectedTarget == player) and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(80, 80, 80)
        Instance.new("UICorner", Indicator).CornerRadius = UDim.new(0, 5)

        Card.MouseButton1Click:Connect(function()
            selectedTarget = player
            UpdatePlayerList()
            UpdateDots()
        end)
    end
    local count = #Scroll:GetChildren()
    Scroll.CanvasSize = UDim2.new(0, 0, 0, count * 40 + 10)
end

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == CONFIG.MenuKey then
        MainFrame.Visible = not MainFrame.Visible
        if MainFrame.Visible then UpdatePlayerList() end
    elseif input.KeyCode == CONFIG.ToggleKey then
        if isActive then
            disableKillMode()
        else
            if selectedTarget then
                enableKillMode(selectedTarget)
            else
                local notif = Instance.new("TextLabel", ScreenGui)
                notif.Text = "Выбери игрока в GUI (P)"
                notif.Position = UDim2.new(0.5, -100, 0.9, 0)
                notif.Size = UDim2.new(0, 200, 0, 30)
                notif.BackgroundColor3 = Color3.fromRGB(0,0,0)
                notif.TextColor3 = Color3.fromRGB(255,200,100)
                notif.BackgroundTransparency = 0.5
                notif.Font = "GothamBold"
                notif.TextSize = 14
                task.wait(2)
                notif:Destroy()
            end
        end
        UpdateDots()
    end
end)

UpdatePlayerList()
