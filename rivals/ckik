local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")
local vim = game:GetService("VirtualInputManager")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local FILE_NAME = "triggerbot_v3_config.json"

local Settings = {
    Enabled = true,
    Radius = 20, 
    OnlyHead = false,
    BlacklistedUsers = {}
}

local function SaveData()
    local data = {Radius = Settings.Radius, BlacklistedUsers = Settings.BlacklistedUsers}
    writefile(FILE_NAME, HttpService:JSONEncode(data))
end

local function LoadData()
    if isfile(FILE_NAME) then
        local s, r = pcall(function() return HttpService:JSONDecode(readfile(FILE_NAME)) end)
        if s and r then
            Settings.Radius = r.Radius or 20
            Settings.BlacklistedUsers = r.BlacklistedUsers or {}
        end
    end
end
LoadData()

local AllHitboxes = {"HitboxBody", "HitboxBodySmall", "HitboxHead", "HitboxHeadSmall", "HumanoidRootPart", "PhysicalHitboxHead"}
local HeadHitboxes = {"HitboxHead", "HitboxHeadSmall", "PhysicalHitboxHead"}
local isLeftClicking = false

local function GetHiddenFolder()
    if gethui then return gethui() end
    return game:GetService("CoreGui"):FindFirstChild("RobloxGui") or game:GetService("CoreGui")
end

