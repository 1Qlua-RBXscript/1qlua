HeadDot.BackgroundColor3 = Settings.OnlyHead and Color3.new(0, 0.5, 1) or Color3.new(0.3, 0.3, 0.3)
HeadDot.BorderSizePixel = 0
HeadDot.Parent = ScreenGui
Instance.new("UICorner").Parent = HeadDot

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 260, 0, 380)
MainFrame.Position = UDim2.new(0.5, -130, 0.5, -190)
