local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local imageList = {
    "rbxassetid://94766523133977",
    "rbxassetid://90282088641639",
    "rbxassetid://138895356591238",
    "rbxassetid://78068916519899",
}
local function playEffect()
    local randomImage = imageList[math.random(1, #imageList)]
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "KillEffectGui"
    screenGui.Parent = CoreGui
    screenGui.IgnoreGuiInset = true 
    local imageLabel = Instance.new("ImageLabel")
    imageLabel.Name = "MainImage"
    imageLabel.Size = UDim2.new(1, 0, 1, 0)
    imageLabel.Position = UDim2.new(0.5, 0, 0.5, 0)
    imageLabel.AnchorPoint = Vector2.new(0.5, 0.5)
    imageLabel.BackgroundTransparency = 1
    imageLabel.Image = randomImage 
    imageLabel.Parent = screenGui
    local duration = 0.25
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
    local goals = {
        Size = UDim2.new(0, 0, 0, 0),
        ImageTransparency = 1
    }
    local tween = TweenService:Create(imageLabel, tweenInfo, goals)
    task.wait(0.05)
    tween:Play()
    tween.Completed:Connect(function()
        screenGui:Destroy()
    end)
end

local function setupListener()
    local playerGui = player:WaitForChild("PlayerGui", 10)
    if not playerGui then return end
    
    local mainGui = playerGui:WaitForChild("MainGui", 10)
    local mainFrame = mainGui:WaitForChild("MainFrame", 10)
    local fighterInterfaces = mainFrame:WaitForChild("FighterInterfaces", 10)
    local userFolder = fighterInterfaces:WaitForChild(player.Name, 10)
    
    if userFolder then
        local targetPath = userFolder:WaitForChild("EliminationSlots", 10)
        
        if targetPath then
            targetPath.ChildAdded:Connect(function()
                playEffect()
            end)
        end
    end
end

task.spawn(setupListener)
player.CharacterAdded:Connect(function()
    task.wait(1) -- Ждем секунду, чтобы GUI успел создаться после респавна
    setupListener()
end)
