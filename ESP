        local bgCorner = Instance.new("UICorner")
        bgCorner.CornerRadius = UDim.new(0, 5)
        bgCorner.Parent = sliderBg
        sliderBg.Parent = container

        local fill = Instance.new("Frame")
        fill.Size = UDim2.new(startVal/max, 0, 1, 0)
        if channel == "R" then
            fill.BackgroundColor3 = Color3.new(1, 0, 0)
        elseif channel == "G" then
            fill.BackgroundColor3 = Color3.new(0, 1, 0)
        elseif channel == "B" then
            fill.BackgroundColor3 = Color3.new(0, 0, 1)
        end
        fill.BorderSizePixel = 0
        local fillCorner = Instance.new("UICorner")
        fillCorner.CornerRadius = UDim.new(0, 5)
        fillCorner.Parent = fill
        fill.Parent = sliderBg

        local valueBox = Instance.new("TextBox")
        valueBox.Size = UDim2.new(0, 40, 0, 30)
        valueBox.Position = UDim2.new(1, -40, 0.5, -15)
        valueBox.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        valueBox.BorderSizePixel = 0
        valueBox.Text = tostring(math.floor(startVal))
        valueBox.TextColor3 = Color3.new(1, 1, 1)
        valueBox.TextSize = 14
        valueBox.Font = Enum.Font.Gotham
        local valueCorner = Instance.new("UICorner")
        valueCorner.CornerRadius = UDim.new(0, 4)
        valueCorner.Parent = valueBox
        valueBox.Parent = container

        local dragging = false
        local function updateFromInput(mousePos)
            if not sliderBg or not sliderBg.AbsolutePosition then return end
            local relativeX = mousePos.X - sliderBg.AbsolutePosition.X
            local scale = math.clamp(relativeX / sliderBg.AbsoluteSize.X, 0, 1)
            fill.Size = UDim2.new(scale, 0, 1, 0)
            local val = math.floor(scale * max)
            valueBox.Text = tostring(val)

            local r, g, b = previewBox.BackgroundColor3.R, previewBox.BackgroundColor3.G, previewBox.BackgroundColor3.B
            if channel == "R" then
                previewBox.BackgroundColor3 = Color3.new(scale, g, b)
            elseif channel == "G" then
                previewBox.BackgroundColor3 = Color3.new(r, scale, b)
            elseif channel == "B" then
                previewBox.BackgroundColor3 = Color3.new(r, g, scale)
            end
        end

        sliderBg.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                updateFromInput(UserInputService:GetMouseLocation())
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                updateFromInput(UserInputService:GetMouseLocation())
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)

        valueBox.FocusLost:Connect(function()
            local val = tonumber(valueBox.Text) or 0
            val = math.clamp(val, 0, max)
            valueBox.Text = tostring(val)
            local scale = val / max
            fill.Size = UDim2.new(scale, 0, 1, 0)

            local r, g, b = previewBox.BackgroundColor3.R, previewBox.BackgroundColor3.G, previewBox.BackgroundColor3.B
            if channel == "R" then
                previewBox.BackgroundColor3 = Color3.new(scale, g, b)
            elseif channel == "G" then
                previewBox.BackgroundColor3 = Color3.new(r, scale, b)
            elseif channel == "B" then
                previewBox.BackgroundColor3 = Color3.new(r, g, scale)
            end
        end)
    end

    local startColor = espData[player] and espData[player].Color or Color3.new(1, 1, 1)
    createSlider("R", "R", 255, startColor.R * 255, 110)
    createSlider("G", "G", 255, startColor.G * 255, 160)
