updateSkeleton = function(player)
    print("🦴 updateSkeleton для", player.Name, "ShowSkeleton =", settings.ShowSkeleton)
    local data = espData[player]
    if not data or not data.Highlight then return end
    data.Highlight.Enabled = settings.ShowSkeleton and data.Enabled
    if settings.TeamESP then
        if player.Team == LocalPlayer.Team then
            data.Highlight.FillColor = Color3.new(0, 1, 0)
        else
            data.Highlight.FillColor = Color3.new(1, 0, 0)
        end
    else
        data.Highlight.FillColor = data.Color
    end
    data.Highlight.FillTransparency = 0.5
    data.Highlight.OutlineColor = Color3.new(1, 1, 1)
    data.Highlight.OutlineTransparency = 0
end

refreshAllESP = function()
    for player, _ in pairs(espData) do
        if updateESP then updateESP(player) end
        if updateSkeleton then updateSkeleton(player) end
    end
end

updateESP = function(player)
    local data = espData[player]
    if not data or not data.Enabled then return end

    local humanoid = data.Humanoid
    local isAlive = humanoid and humanoid.Health > 0

    if data.Billboard then
        data.Billboard.Enabled = isAlive
    end

    if not isAlive then return end

    local health = humanoid.Health
    local maxHealth = humanoid.MaxHealth
    local healthPercent = math.clamp(health / maxHealth, 0, 1)
    local healthText = string.format("%.0f", healthPercent * 100) .. "%"

    local displayText = ""
    if settings.ShowName then
        displayText = player.Name
    end
    if settings.ShowHealth then
        if displayText ~= "" then
            displayText = displayText .. " - " .. healthText
        else
            displayText = healthText
        end
    end
    if settings.ShowDistance and data.Head then
        local distance = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head")) and
                        (data.Head.Position - LocalPlayer.Character.Head.Position).Magnitude or 0
        if displayText ~= "" then
            displayText = displayText .. " [" .. math.floor(distance) .. "m]"
        else
            displayText = "[" .. math.floor(distance) .. "m]"
        end
    end

    if data.TextLabel then
        data.TextLabel.Text = displayText
        data.TextLabel.TextColor3 = data.Color
        data.TextLabel.TextSize = settings.TextSize
        data.TextLabel.Visible = (settings.ShowName or settings.ShowHealth or settings.ShowDistance) and isAlive
    end

    if data.HealthBar and data.HealthBarBg then
        data.HealthBar.Size = UDim2.new(healthPercent, 0, 0, 5)
        data.HealthBar.Visible = settings.ShowHealthBar and isAlive
        data.HealthBarBg.Visible = settings.ShowHealthBar and isAlive
    end
end

createESP = function(player, color)
    print("🆕 createESP для", player.Name, "цвет", color)
    if player == LocalPlayer then return end
    if espData[player] then
        if espData[player].Billboard then espData[player].Billboard:Destroy() end
        if espData[player].Highlight then espData[player].Highlight:Destroy() end
        espData[player] = nil
    end

    local function onCharacterAdded(character)
        print("👤 onCharacterAdded для", player.Name)
        local head = character:WaitForChild("Head")
        local humanoid = character:WaitForChild("Humanoid")

        -- Billboard (текст и полоска)
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "ESP_"..player.Name
        billboard.Adornee = head
        billboard.Size = UDim2.new(0, 200, 0, 50)
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.AlwaysOnTop = true
        billboard.LightInfluence = 0
        billboard.Parent = screenGui

        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 1, 0)
        frame.BackgroundTransparency = 1
        frame.Parent = billboard

        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, 0, 0, 30)
        textLabel.Position = UDim2.new(0, 0, 0, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.TextColor3 = color or Color3.new(1, 1, 1)
        textLabel.TextStrokeTransparency = 0.5
        textLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
        textLabel.Font = Enum.Font.GothamBold
        textLabel.TextSize = settings.TextSize
        textLabel.Text = player.Name .. " - 100%"
        textLabel.Parent = frame

        local healthBarBg = Instance.new("Frame")
        healthBarBg.Size = UDim2.new(1, 0, 0, 5)
        healthBarBg.Position = UDim2.new(0, 0, 1, -5)
        healthBarBg.BackgroundColor3 = Color3.new(1, 0, 0)
        healthBarBg.BackgroundTransparency = 0.5
        healthBarBg.BorderSizePixel = 0
        healthBarBg.Parent = frame

        local healthBar = Instance.new("Frame")
        healthBar.Size = UDim2.new(1, 0, 0, 5)
        healthBar.Position = UDim2.new(0, 0, 1, -5)
        healthBar.BackgroundColor3 = Color3.new(0, 1, 0)
        healthBar.BorderSizePixel = 0
        healthBar.Parent = frame

        -- Highlight (скелет)
        local highlight = Instance.new("Highlight")
        highlight.Name = "Highlight_"..player.Name
        highlight.Adornee = character
        highlight.FillColor = color or Color3.new(1, 1, 1)
        highlight.FillTransparency = 0.5
        highlight.OutlineColor = Color3.new(1, 1, 1)
        highlight.OutlineTransparency = 0
        highlight.Enabled = settings.ShowSkeleton
        highlight.Parent = screenGui

        espData[player] = {
            Billboard = billboard,
            TextLabel = textLabel,
            HealthBar = healthBar,
            HealthBarBg = healthBarBg,
            Highlight = highlight,
            Color = color or Color3.new(1, 1, 1),
            Enabled = true,
            Humanoid = humanoid,
            Head = head
        }

        if settings.TeamESP then
            if player.Team == LocalPlayer.Team then
                setESPColor(player, Color3.new(0, 1, 0))
            else
                setESPColor(player, Color3.new(1, 0, 0))
            end
        end

        updateESP(player)
        updateSkeleton(player)

        humanoid.HealthChanged:Connect(function()
            updateESP(player)
        end)
    end

    if player.Character then
        onCharacterAdded(player.Character)
    end

    player.CharacterAdded:Connect(onCharacterAdded)
end

removeESP = function(player)
    if espData[player] then
        if espData[player].Billboard then espData[player].Billboard:Destroy() end
        if espData[player].Highlight then espData[player].Highlight:Destroy() end
        espData[player] = nil
    end
end

removeAllESP = function()
    for player, _ in pairs(espData) do
        removeESP(player)
    end
end

toggleESP = function(player, enabled)
    if espData[player] then
        espData[player].Enabled = enabled
        if espData[player].Billboard then
            espData[player].Billboard.Enabled = enabled and espData[player].Humanoid and espData[player].Humanoid.Health > 0
        end
        updateSkeleton(player)
    end
end

setESPColor = function(player, color)
    if espData[player] then
        espData[player].Color = color
        if espData[player].TextLabel then
            espData[player].TextLabel.TextColor3 = color
        end
        if espData[player].Highlight then
            espData[player].Highlight.FillColor = color
        end
    end
end

toggleAllESP = function(state)
    for player, row in pairs(playerRows) do
        if not espData[player] then
            createESP(player, Color3.new(1, 1, 1))
        end
        toggleESP(player, state)
        local checkbox = row and row:FindFirstChild("Checkbox")
        if checkbox then
            checkbox.Text = state and "✓" or ""
        end
    end
end

